    "lint": "eslint --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "3.7.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.50.1"
  }
}
