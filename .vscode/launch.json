{
  "version": "0.2.0",
  "configurations": [
    // Backend Launch
    {
      "name": "Backend Launch",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--experimental-specifier-resolution=node",
        "dist/src/main.js"
      ],
      "preLaunchTask": "Start NestJS Backend (Dev)",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    // Backend Attach
    {
      "name": "Backend Attach",
      "type": "node",
      "request": "attach",
      "cwd": "${workspaceFolder}/apps/backend",
      "port": 9229,
      "preLaunchTask": "Start NestJS Backend (Debug)",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    // Backend Tests Launch
    {
      "name": "Backend Tests Launch",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/backend",
      "runtimeArgs": [
        "--inspect-brk",
        "${workspaceFolder}/node_modules/jest/bin/jest.js",
        "--runInBand",
        "--config",
        "./test/jest-e2e.json"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "port": 9229
    },
    // Frontend Launch
    {
      "name": "Frontend Launch",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/client/src",
      "preLaunchTask": "Start Vite Dev Server"
    }
  ],
  "compounds": [
    {
      "name": "Launch Frontend + Backend",
      "configurations": [
        "Backend Launch",
        "Frontend Launch"
      ]
    }
  ]
}