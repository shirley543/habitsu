{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend (NestJS)",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--experimental-specifier-resolution=node",
        "dist/src/main.js"
      ],
      "preLaunchTask": "Start NestJS Backend",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Debug Client (Vite)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/client/src",
      "preLaunchTask": "Start Vite Dev Server"
    }
  ],
  "compounds": [
    {
      "name": "Debug Client + Backend",
      "configurations": [
        "Debug Backend (NestJS)",
        "Debug Client (Vite)"
      ]
    }
  ]
}